{
  "rules": {
    "clientes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "login": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "usuarios": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
